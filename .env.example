# Variables de entorno para Docker Compose y despliegue en Railway/Render
# Copiar este archivo a .env y ajustar valores antes de ejecutar

JWT_SECRET=clave_veterinaria_super_secreta_2026_muy_larga

DB_USER=appuser
DB_PASSWORD=1234

# Cada microservicio usa estas variables de entorno en application.yml:
# DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD, JWT_SECRET

# Railway: mapear MYSQLHOST -> DB_HOST, MYSQLPORT -> DB_PORT, etc.
# Cloud: usar server.port=${PORT:808x} (ya configurado en application.yml)

# Servicios y puertos:
# ms-auth         -> 8083  (BD: ms-user)
# ms-veterinarios -> 8084  (BD: ms-veterinario)
# ms-mascotas     -> 8085  (BD: ms-mascota)
# ms-usuarios     -> 8086  (BD: ms-usuario)
# ms-facturacion  -> 8087  (BD: ms-facturacion)
# ms-tratamientos -> 8089  (BD: ms-tratamiento)
# ms-inventario   -> 8092  (BD: ms-inventario)
# ms-resena       -> 8094  (BD: ms-resena)
# ms-citas        -> 8095  (BD: ms-citas)
# ms-historial    -> 8098  (BD: ms-historial_medico)
